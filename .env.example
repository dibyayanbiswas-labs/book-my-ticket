# Server
PORT=5000
NODE_ENV=production

# Database — localhost docker container
DATABASE_URL=local_docker_container_url

# JWT
JWT_ACCESS_SECRET_KEY=change_me_to_a_strong_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET_KEY=change_me_to_another_strong_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS — set this to your frontend URL in production
CORS_ORIGIN=*